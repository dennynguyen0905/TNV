# ─────────────────────────────────────────────────────────────────────────────
# LangPath environment configuration
#
# Copy to `.env` for local dev:  cp .env.example .env
# In production set these in your host's env (Vercel dashboard, Docker, etc.).
# Never commit a real `.env`. `.env` is gitignored.
#
# Legend:  [REQUIRED] must be set   [REQUIRED IN PROD]   [OPTIONAL] safe default
# The healthcheck at /api/health validates the production-critical ones.
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Node runtime mode. Leave as "development" locally; hosts set
# "production" automatically. Controls cookie `secure` flag and log verbosity.
NODE_ENV="development"

# ─── Database ────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string. The app and Prisma CLI both read this.
# Local default matches docker-compose.yml. In production use a managed Postgres
# (Supabase / Neon / Railway / Vercel Postgres) and a POOLED connection string
# for serverless. NOTE (Prisma 7): the CLI does NOT auto-load .env — export
# DATABASE_URL in your shell before `prisma db push` / `tsx prisma/seed.ts`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/language_learning_platform?schema=public"

# ─── Public site origin (SEO) ────────────────────────────────────────────────
# [REQUIRED IN PROD] Canonical origin for sitemap, robots, canonical tags and
# JSON-LD. No trailing slash. NEXT_PUBLIC_SITE_URL wins; NEXT_PUBLIC_APP_URL is
# the fallback. Falls back to http://localhost:3000 if neither is set.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_SITE_URL="https://thang-nv.vercel.app"

# ─── Auth / session ──────────────────────────────────────────────────────────
# [REQUIRED IN PROD] Reserved secret for future token signing. Sessions today use
# crypto.randomBytes + SHA-256 (no secret needed), but set a unique random value
# in production anyway: `openssl rand -hex 32`. The healthcheck warns if it is
# left at this placeholder.
AUTH_SECRET="replace-with-a-secure-random-secret"

# [OPTIONAL] Session cookie name. Defaults to "llp_session" if unset.
SESSION_COOKIE_NAME="llp_session"

# ─── Deferred subsystem drivers (placeholders — do not change in prod yet) ────
# These select local/no-op implementations. Object storage, a real search engine
# (Typesense), and a background queue (Redis) are deferred to a later phase.
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR="public/uploads"
SEARCH_DRIVER="database"
WORKER_DRIVER="local"

# ─── Payments (deferred) ─────────────────────────────────────────────────────
# [KEEP false] Premium is a placeholder gate only. No checkout/provider/webhook
# is wired. The healthcheck warns if this is "true".
PAYMENT_ENABLED="false"

# ─── Build metadata (optional, surfaced at /api/version) ─────────────────────
# [OPTIONAL] On Vercel, VERCEL_GIT_COMMIT_SHA is provided automatically. For
# Docker/VPS builds you may inject these to identify the running build.
# BUILD_SHA="abc1234"
# BUILD_TIME="2026-06-12T00:00:00Z"
